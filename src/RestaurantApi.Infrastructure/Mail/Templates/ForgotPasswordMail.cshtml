@model RestaurantApi.Application.Models.MailModels.ForgotPasswordViewModel

<div style="margin-bottom: 25px;">
    <h2 style="color: #1a1a1a; font-size: 22px; margin: 0 0 10px 0;">Merhaba @Model.CustomerName,</h2>
    <p style="color: #555; font-size: 15px; margin: 0; line-height: 1.5;">
        @Model.Description
    </p>
</div>

<div style="text-align: center; margin: 35px 0;">
    <a href="@Model.ResetLink" 
       target="_blank" 
       style="display: inline-block; background-color: #d4691d; color: #ffffff; font-family: 'Segoe UI', Helvetica, Arial, sans-serif; font-size: 16px; font-weight: 700; text-decoration: none; padding: 14px 45px; border-radius: 8px; box-shadow: 0 4px 6px rgba(212, 105, 29, 0.2); transition: background-color 0.2s ease;">
        Şifremi Sıfırla
    </a>
    
    <p style="color: #888; font-size: 13px; margin: 15px 0 0 0;">
        ⏳ Bu bağlantı güvenlik nedeniyle <strong>@Model.ExpireInMinutes dakika</strong> süreyle geçerlidir.
    </p>
</div>

<div style="background-color: #fafafa; border: 1px solid #eee; border-radius: 8px; padding: 20px; margin-bottom: 30px;">
    <h3 style="font-size: 13px; color: #555; text-transform: uppercase; margin: 0 0 12px 0; letter-spacing: 1px;">Güvenlik Bilgileri</h3>
    
    <table style="width: 100%; font-size: 14px; color: #444; border-collapse: collapse;">
        <tr>
            <td style="padding: 5px 0; font-weight: 600; width: 120px; vertical-align: top;">İlgili Hesap:</td>
            <td style="padding: 5px 0; vertical-align: top;">@Model.CustomerEmail</td>
        </tr>
        <tr>
            <td style="padding: 5px 0; font-weight: 600; vertical-align: top;">Link Kopyala:</td>
            <td style="padding: 5px 0; color: #666; font-size: 12px; word-break: break-all; font-family: monospace;">
                Eğer buton çalışmıyorsa bu linki tarayıcınıza yapıştırabilirsiniz:<br />
                <a href="@Model.ResetLink" style="color: #d4691d; text-decoration: underline;">@Model.ResetLink</a>
            </td>
        </tr>
        <tr>
            <td style="padding: 10px 0 5px 0; font-weight: 600; vertical-align: top;">Güvenlik Uyarısı:</td>
            <td style="padding: 10px 0 5px 0; color: #666; font-size: 13px; font-style: italic; vertical-align: top;">
                Bu şifre sıfırlama talebi sizin tarafınızdan <strong>yapılmadıysa</strong>, bu e-postayı güvenle yok sayabilirsiniz. Hesabınız hâlâ güvendedir.
            </td>
        </tr>
    </table>
</div>

<div style="margin-top: 25px; border-top: 1px solid #eee; padding-top: 20px; font-size: 12px; color: #999; text-align: center;">
    Bu e-posta güvenliğiniz için otomatik olarak gönderilmiştir. Lütfen bu maili kimseyle paylaşmayın.<br />
    <strong>© @DateTime.Now.Year @Model.RestaurantName. All Rights Reserved.</strong>
</div>