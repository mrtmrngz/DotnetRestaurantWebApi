@model RestaurantApi.Infrastructure.Mail.Templates.ViewModels.MailLayoutModel

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Model.Title</title>
</head>
<body style="margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; line-height: 1.6; color: #333; background-color: #f4f4f4;">
    
    <div style="max-width: 600px; margin: 20px auto; background-color: #ffffff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);">
        
        <!-- Header / Banner -->
        <div style="background: linear-gradient(135deg, #d4691d 0%, #a34e12 100%); padding: 50px 20px; text-align: center; color: white;">
            <h1 style="font-size: 32px; font-weight: 800; margin: 0; letter-spacing: -1px; text-transform: uppercase;">@Model.RestaurantName</h1>
            <div style="width: 50px; height: 3px; background: rgba(255,255,255,0.3); margin: 15px auto;"></div>
        </div>

        <!-- Main Content Area -->
        <div style="padding: 40px 35px;">
            @Raw(Model.Body)
        </div>

        <!-- Footer -->
        <div style="background-color: #1a1a1a; color: #888; padding: 30px; font-size: 12px; text-align: center;">
            <div style="margin-bottom: 15px;">
                <p style="margin: 0; color: #bbb; font-weight: 600;">@Model.RestaurantName</p>
                <p style="margin: 5px 0 0 0;">Lezzetin dijital adresi.</p>
            </div>
            <div style="border-top: 1px solid #333; padding-top: 15px; margin-top: 15px;">
                © @Model.Year Tüm hakları saklıdır. <br/>
                Bu e-posta otomatik olarak gönderilmiştir, lütfen yanıtlamayınız.
            </div>
        </div>
    </div>
</body>
</html>